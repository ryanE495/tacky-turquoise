---
import { colorways } from '../data/categories';
const PRODUCT_IMG = 'https://bswmrfxdadcmuyhmsagv.supabase.co/storage/v1/object/public/portfolio-images/test.jpeg';
---
<section class="cats">
  <div class="section-head">
    <span class="num">02 / Colorways</span>
    <h2 class="reveal">The <em>family</em></h2>
    <a href="#" class="link reveal reveal--d1">See all →</a>
  </div>
  <div class="cats__grid">
    {colorways.map((c) => (
      <a href="#" class="cat reveal">
        <img src={PRODUCT_IMG} alt={c.name} />
        <div class="cat__label">
          <span>{c.name}</span>
          <span class="count">{c.note}</span>
        </div>
      </a>
    ))}
  </div>
</section>
