---
const reviews = [
  {
    quote: "Exceeded every expectation — this piece is special to me in a way I can't quite put into words.",
    name: 'Madison M.',
    piece: 'Turquoise strand necklace',
  },
  {
    quote: 'Dainty, timeless, perfect for layering. I get compliments every single time I wear it.',
    name: 'Sarah R.',
    piece: 'Mini bead necklace',
  },
  {
    quote: 'Stunned by the craftsmanship. Worth every day of the wait — my favorite piece, full stop.',
    name: 'Zoë W.',
    piece: 'Cluster bead necklace',
  },
  {
    quote: "I knew this one was mine the second it dropped. It's even better in person than the photos.",
    name: 'Brittany D.',
    piece: 'Statement bead necklace',
  },
  {
    quote: 'Daily wear ever since it arrived. Quality is unreal and the color is alive — I always get compliments.',
    name: 'Casey D.',
    piece: 'Long bead necklace',
  },
  {
    quote: "Exceeded my expectations at an impossibly fair price. So glad I trusted my gut and ordered.",
    name: 'Sarah A.',
    piece: 'Pearl + turquoise necklace',
  },
];
---
<section class="reviews">
  <div class="reviews__head">
    <div class="reviews__eyebrow">★★★★★  ·  Real customers, real pieces</div>
    <h2 class="reviews__title">Customers are <em>saying.</em></h2>
  </div>
  <div class="reviews__grid">
    {reviews.map((r) => (
      <figure class="review">
        <div class="review__stars" aria-hidden="true">★ ★ ★ ★ ★</div>
        <blockquote class="review__quote">"{r.quote}"</blockquote>
        <figcaption class="review__cap">
          <span class="review__name">{r.name}</span>
          <span class="review__sep" aria-hidden="true">—</span>
          <span class="review__piece">{r.piece}</span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
