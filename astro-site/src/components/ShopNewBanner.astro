---
const BG = 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/fa674f03-6145-4b55-9feb-83ce320f846d.webp';
---
<section class="ed-banner ed-banner--new" aria-labelledby="shop-new-h">
  <a class="ed-banner__link" href="/shop">
    <img class="ed-banner__img" src={BG} alt="" />
    <div class="ed-banner__overlay"></div>
    <div class="ed-banner__content">
      <div class="ed-banner__eyebrow">New arrivals · Ready to ship</div>
      <h2 id="shop-new-h" class="ed-banner__title">Shop <em>new.</em></h2>
      <p class="ed-banner__sub">The latest pieces from the studio — one of one and ready to ship from Montrose.</p>
      <span class="ed-banner__cta">
        <span>Shop new</span>
        <span class="arrow" aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</section>
