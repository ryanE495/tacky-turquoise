---
const PLACEHOLDER = '/images/hero.webp';
const cards = [
  { label: 'Necklaces',              em: '!', href: '/shop?cat=necklace', image: PLACEHOLDER },
  { label: 'Cuffs',                  em: '!', href: '/shop?cat=cuff',     image: PLACEHOLDER },
  { label: 'The Heirloom Collection',em: '!', href: '/shop?cat=featured', image: PLACEHOLDER },
];
---
<section class="cat-ctas">
  {cards.map((c) => (
    <a class="cat-cta" href={c.href}>
      <div class="cat-cta__img"><img src={c.image} alt="" /></div>
      <div class="cat-cta__body">
        <span class="cat-cta__label">
          {c.label}<em>{c.em}</em>
        </span>
        <span class="cat-cta__browse">Browse <span class="arrow" aria-hidden="true">→</span></span>
      </div>
    </a>
  ))}
</section>
