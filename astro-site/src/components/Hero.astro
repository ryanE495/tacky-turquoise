---
import Nav from './Nav.astro';
import { fetchDropSettings } from '../lib/supabase';

const HERO_LOGO = 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/7389f97c-ffe8-4070-9498-518ed4c72234.webp';

let drop = null;
try {
  drop = await fetchDropSettings();
} catch (e) {
  console.warn('[Hero] drop_settings fetch failed:', e);
}

const dropEnabled = !!(drop && drop.enabled && drop.drops_at);
const dropTargetISO = drop?.drops_at ?? '';
const dropName = drop?.name ?? 'Next drop';
const dropLocation = drop?.location ?? '';
const shopUrl = drop?.shop_url || '/shop';

function formatDropHuman(iso: string, name: string, location: string): string {
  if (!iso) return name;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return name;
  const date = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'America/Denver' });
  const time = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'America/Denver' });
  const parts = [name, date, `${time} MT`];
  if (location) parts.push(location);
  return parts.filter(Boolean).join('  ·  ');
}

const dropHuman = dropEnabled ? formatDropHuman(dropTargetISO, dropName, dropLocation) : '';
const heroEyebrow = dropEnabled ? `Vol. 07 · ${dropName}` : `Vol. 07 · Tacky Turquoise`;
---

<header class="hero2" id="hero">
  <Nav />

  <!-- Two-column stage: gallery left, text right -->
  <div class="hero2__stage">
    <div class="hero2__logo" aria-hidden="true">
      <img src={HERO_LOGO} alt="Tacky Turquoise" loading="eager" />
    </div>

    <div class="hero2__content">
      <div class="hero2__eyebrow reveal">
        <span class="dot" aria-hidden="true"></span>
        <span>{heroEyebrow}</span>
      </div>

      <h1 class="hero2__title reveal reveal--d1">
        Real stone, one of <em>one.</em>
      </h1>

      <p class="hero2__sub reveal reveal--d2">
        Every piece is hand-strung and made one at a time
        in Montrose, Colorado.
      </p>

      <div class="hero2__actions reveal reveal--d3">
        <a href={shopUrl} class="hero2__cta">
          <span>Shop the drop</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        {dropEnabled && (
          <a href="#next-drop" class="hero2__second">See what's next ↓</a>
        )}
      </div>
    </div>
  </div>
</header>

<!-- NEXT DROP COUNTDOWN -->
{dropEnabled && (
  <section class="next-drop" id="next-drop" data-supabase-url={import.meta.env.PUBLIC_SUPABASE_URL} data-supabase-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}>
    <div class="next-drop__inner">
      <div class="next-drop__lead">
        <div class="next-drop__eyebrow">
          <span class="dot" aria-hidden="true"></span>
          <span data-drop-human>{dropHuman}</span>
        </div>
        <h2 class="next-drop__title">Next <em>drop.</em></h2>
        <a href={shopUrl} class="next-drop__cta" data-drop-cta>
          <span>Shop the drop</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="next-drop__right">
        <div class="countdown" id="countdown" data-target={dropTargetISO} aria-live="polite">
          <div class="countdown__cell"><span class="n" data-unit="d">00</span><span class="lbl">Days</span></div>
          <div class="countdown__sep" aria-hidden="true">:</div>
          <div class="countdown__cell"><span class="n" data-unit="h">00</span><span class="lbl">Hours</span></div>
          <div class="countdown__sep" aria-hidden="true">:</div>
          <div class="countdown__cell"><span class="n" data-unit="m">00</span><span class="lbl">Minutes</span></div>
          <div class="countdown__sep" aria-hidden="true">:</div>
          <div class="countdown__cell"><span class="n" data-unit="s">00</span><span class="lbl">Seconds</span></div>
        </div>

        <div class="countdown__live" id="countdown-live" hidden>The drop is <em>live</em>. Go.</div>
      </div>
    </div>
  </section>
)}

<script>
  (function () {
    const section = document.getElementById('next-drop');
    const el = document.getElementById('countdown');
    if (!section || !el) return;

    const units: Record<string, HTMLElement> = {
      d: el.querySelector<HTMLElement>('[data-unit="d"]')!,
      h: el.querySelector<HTMLElement>('[data-unit="h"]')!,
      m: el.querySelector<HTMLElement>('[data-unit="m"]')!,
      s: el.querySelector<HTMLElement>('[data-unit="s"]')!,
    };
    const live = document.getElementById('countdown-live');
    const humanEl = section.querySelector<HTMLElement>('[data-drop-human]');
    const ctaEl = section.querySelector<HTMLAnchorElement>('[data-drop-cta]');

    let target = new Date(el.dataset.target!).getTime();

    function pad(n: number) { return n < 10 ? '0' + n : String(n); }

    function tick() {
      if (!Number.isFinite(target)) return;
      const diff = target - Date.now();
      if (diff <= 0) {
        Object.values(units).forEach((u) => (u.textContent = '00'));
        el!.setAttribute('data-done', 'true');
        if (live) live.hidden = false;
        return;
      }
      el!.removeAttribute('data-done');
      if (live) live.hidden = true;
      const d = Math.floor(diff / (1000 * 60 * 60 * 24));
      const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const m = Math.floor((diff / (1000 * 60)) % 60);
      const s = Math.floor((diff / 1000) % 60);
      units.d.textContent = pad(d);
      units.h.textContent = pad(h);
      units.m.textContent = pad(m);
      units.s.textContent = pad(s);
    }
    tick();
    const interval = window.setInterval(tick, 1000);
    window.addEventListener('beforeunload', () => window.clearInterval(interval));

    function formatHuman(iso: string, name: string, location: string | null): string {
      if (!iso) return name;
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return name;
      const date = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'America/Denver' });
      const time = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'America/Denver' });
      const parts = [name, date, `${time} MT`];
      if (location) parts.push(location);
      return parts.filter(Boolean).join('  ·  ');
    }

    async function refreshDrop() {
      const url = section!.dataset.supabaseUrl;
      const key = section!.dataset.supabaseKey;
      if (!url || !key) return;
      try {
        const res = await fetch(`${url}/rest/v1/drop_settings?select=*&order=id.asc&limit=1`, {
          headers: { apikey: key, Authorization: `Bearer ${key}` },
        });
        if (!res.ok) return;
        const rows = await res.json();
        const row = Array.isArray(rows) ? rows[0] : null;
        if (!row) return;

        if (!row.enabled || !row.drops_at) {
          section!.hidden = true;
          return;
        }

        const newTarget = new Date(row.drops_at).getTime();
        if (Number.isFinite(newTarget) && newTarget !== target) {
          target = newTarget;
          el!.dataset.target = row.drops_at;
          tick();
        }
        if (humanEl) humanEl.textContent = formatHuman(row.drops_at, row.name ?? 'Next drop', row.location ?? null);
        if (ctaEl && row.shop_url) ctaEl.href = row.shop_url;
      } catch {
        /* ignore — keep static values */
      }
    }
    refreshDrop();
  })();
</script>
