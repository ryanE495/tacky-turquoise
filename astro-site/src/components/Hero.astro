---
import Nav from './Nav.astro';

// Gallery tiles — each maps to a unique image + object-position
const tiles = [
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/2d6b0b22-9dbc-42b2-8cae-e5acd419875c.webp', pos: '50% 50%' },
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/15a37aad-7339-4d64-ba14-a9fd944718e8.webp', pos: '50% 50%' },
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/6610720e-2a1b-4fbb-8c5a-fc1cb65a2099.webp', pos: '50% 50%' },
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/41c87e3c-212d-4ca3-8e8b-7bfd00fad187.webp', pos: '50% 50%' },
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/4fbd75cc-e1d2-4646-a4ec-81ec54979a1c.webp', pos: '50% 50%' },
  { src: 'https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/0f54f65c-3c9a-4925-99a7-a8d88768dc77.webp', pos: '50% 50%' },
];

const dropTargetISO = '2026-05-20T18:00:00-06:00';
const dropHuman = 'Spring Drop \u201926  ·  May 20  ·  6 PM MT';
---

<header class="hero2" id="hero">
  <Nav />

  <!-- Two-column stage: gallery left, text right -->
  <div class="hero2__stage">
    <div class="hero2__gallery" aria-hidden="true">
      {tiles.map((t) => (
        <div class="hero2__tile">
          <img src={t.src} alt="" style={`object-position: ${t.pos};`} loading="eager" />
        </div>
      ))}
    </div>

    <div class="hero2__content">
      <div class="hero2__eyebrow reveal">
        <span class="dot" aria-hidden="true"></span>
        <span>Vol. 07 · Spring Drop '26</span>
      </div>

      <h1 class="hero2__title reveal reveal--d1">
        Handmade, <em>heirloom</em> pieces.
      </h1>

      <p class="hero2__sub reveal reveal--d2">
        All our pieces are cut, set, and prayed over by hand in
        the high desert of Gallup, New Mexico.
      </p>

      <div class="hero2__actions reveal reveal--d3">
        <a href="/shop" class="hero2__cta">
          <span>Shop the drop</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a href="#next-drop" class="hero2__second">See what's next ↓</a>
      </div>
    </div>
  </div>
</header>

<!-- NEXT DROP COUNTDOWN -->
<section class="next-drop" id="next-drop">
  <div class="next-drop__inner">
    <div class="next-drop__lead">
      <div class="next-drop__eyebrow">
        <span class="dot" aria-hidden="true"></span>
        <span>{dropHuman}</span>
      </div>
      <h2 class="next-drop__title">Next <em>drop.</em></h2>
      <a href="/shop" class="next-drop__cta">
        <span>Shop the drop</span>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <div class="next-drop__right">
      <div class="countdown" id="countdown" data-target={dropTargetISO} aria-live="polite">
        <div class="countdown__cell"><span class="n" data-unit="d">00</span><span class="lbl">Days</span></div>
        <div class="countdown__sep" aria-hidden="true">:</div>
        <div class="countdown__cell"><span class="n" data-unit="h">00</span><span class="lbl">Hours</span></div>
        <div class="countdown__sep" aria-hidden="true">:</div>
        <div class="countdown__cell"><span class="n" data-unit="m">00</span><span class="lbl">Minutes</span></div>
        <div class="countdown__sep" aria-hidden="true">:</div>
        <div class="countdown__cell"><span class="n" data-unit="s">00</span><span class="lbl">Seconds</span></div>
      </div>

      <div class="countdown__live" id="countdown-live" hidden>The drop is <em>live</em>. Go.</div>
    </div>
  </div>
</section>

<script>
  (function () {
    const el = document.getElementById('countdown');
    if (!el) return;
    const target = new Date(el.dataset.target!).getTime();
    const units: Record<string, HTMLElement> = {
      d: el.querySelector<HTMLElement>('[data-unit="d"]')!,
      h: el.querySelector<HTMLElement>('[data-unit="h"]')!,
      m: el.querySelector<HTMLElement>('[data-unit="m"]')!,
      s: el.querySelector<HTMLElement>('[data-unit="s"]')!,
    };
    const live = document.getElementById('countdown-live');

    function pad(n: number) { return n < 10 ? '0' + n : String(n); }

    function tick() {
      const diff = target - Date.now();
      if (diff <= 0) {
        Object.values(units).forEach((u) => (u.textContent = '00'));
        el!.setAttribute('data-done', 'true');
        if (live) live.hidden = false;
        return;
      }
      const d = Math.floor(diff / (1000 * 60 * 60 * 24));
      const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const m = Math.floor((diff / (1000 * 60)) % 60);
      const s = Math.floor((diff / 1000) % 60);
      units.d.textContent = pad(d);
      units.h.textContent = pad(h);
      units.m.textContent = pad(m);
      units.s.textContent = pad(s);
    }
    tick();
    const interval = window.setInterval(tick, 1000);
    window.addEventListener('beforeunload', () => window.clearInterval(interval));
  })();
</script>
