---
interface Props {
  title?: string;
}
const { title = 'Tacky Turquoise — Real Stone. Real Hands. Real Loud.' } = Astro.props;

import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/components.css';
import '../styles/hero2.css';
import '../styles/editorial.css';
import '../styles/cart-checkout.css';
import '../styles/mobile-menu.css';

import MobileMenu from '../components/MobileMenu.astro';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Monoton&family=Sacramento&family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <slot />
    <MobileMenu />

    <script>
      // Reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) if (e.isIntersecting) e.target.classList.add('in');
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
