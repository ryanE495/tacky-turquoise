---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Order confirmed — Tacky Turquoise">
  <section class="storefront-page">
    <div class="storefront-page__inner">
      <div id="success-root" class="storefront-loading">Confirming your payment<span aria-hidden="true">&hellip;</span></div>
    </div>
  </section>
  <Footer />
</Base>

<script>
  import { clearCart } from '../../lib/cart';
  import { formatPrice } from '../../lib/format';
  import { renderSummaryRow, sumCents, type CartItemData } from '../../lib/cart-render';

  const API_BASE = import.meta.env.PUBLIC_API_URL;

  interface OrderItem {
    product_id: string;
    slug: string;
    piece_id: string | null;
    title: string;
    price_cents: number;
    primary_image_url: string | null;
  }
  interface OrderData {
    status: 'pending' | 'paid' | 'cancelled' | string;
    order_number: string;
    customer_name: string;
    customer_email: string;
    items: OrderItem[];
    subtotal_cents: number;
    shipping_cents: number;
    tax_cents?: number;
    total_cents: number;
    shipping_address: {
      line1: string;
      line2?: string | null;
      city: string;
      state: string;
      postal_code: string;
      country: string;
    };
  }

  const root = document.getElementById('success-root')!;

  function esc(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderLoading() {
    root.className = 'storefront-loading';
    root.innerHTML = 'Confirming your payment<span aria-hidden="true">&hellip;</span>';
  }

  function renderCancelled() {
    root.className = 'order-failed';
    root.innerHTML = `
      <div class="order-failed__eyebrow">Checkout cancelled</div>
      <h1 class="order-failed__title">Your checkout was <em>cancelled.</em></h1>
      <p class="order-failed__body">Your cart has been saved. You can return to checkout anytime.</p>
      <div class="order-failed__actions">
        <a href="/cart" class="btn-primary">Return to cart <span aria-hidden="true">&rarr;</span></a>
        <a href="/shop" class="btn-secondary">Keep shopping</a>
      </div>
    `;
  }

  function renderNotFound() {
    root.className = '';
    root.innerHTML = `
      <div class="cart-empty">
        <h2 class="cart-empty__title">We couldn't find that <em>order.</em></h2>
        <p class="cart-empty__sub">Check the link, or head back to the shop.</p>
        <a class="cart-empty__link" href="/">Back home <span aria-hidden="true">&rarr;</span></a>
      </div>
    `;
  }

  function renderPending() {
    root.className = '';
    root.innerHTML = `
      <div class="cart-empty">
        <h2 class="cart-empty__title">Payment is <em>processing.</em></h2>
        <p class="cart-empty__sub">Your payment was accepted. We're finalizing the details — you'll receive an email shortly with your order confirmation.</p>
        <a class="cart-empty__link" href="/shop">Keep browsing <span aria-hidden="true">&rarr;</span></a>
      </div>
    `;
  }

  function buildSummaryHtml(order: OrderData): string {
    const items: CartItemData[] = order.items.map((it) => ({
      id: it.product_id,
      slug: it.slug,
      piece_id: it.piece_id,
      title: it.title,
      price_cents: it.price_cents,
      primary_image_url: it.primary_image_url,
      length: null,
      turquoise_type: null,
      metal: null,
    }));
    const subtotal = order.subtotal_cents ?? sumCents(items);
    const shipping = order.shipping_cents ?? 0;
    const tax = order.tax_cents ?? 0;
    const total = order.total_cents ?? subtotal + shipping + tax;

    return `
      <div class="order-summary">
        <div class="order-summary__heading">Your order</div>
        <div class="order-summary__items">
          ${items.map((it) => renderSummaryRow(it)).join('')}
        </div>
        <div class="order-summary__lines">
          <div class="order-summary__line">
            <span class="label">Subtotal</span>
            <span class="value">${formatPrice(subtotal)}</span>
          </div>
          <div class="order-summary__line">
            <span class="label">Shipping</span>
            <span class="value">${formatPrice(shipping)}</span>
          </div>
          ${tax ? `
          <div class="order-summary__line">
            <span class="label">Tax</span>
            <span class="value">${formatPrice(tax)}</span>
          </div>` : ''}
        </div>
        <div class="order-summary__total">
          <span class="label">Total</span>
          <span class="value">${formatPrice(total)}</span>
        </div>
      </div>
    `;
  }

  function buildShippingHtml(order: OrderData): string {
    const a = order.shipping_address;
    return `
      <div class="order-card">
        <div class="order-card__title">Shipping to</div>
        <div>${esc(order.customer_name)}</div>
        <div>${esc(a.line1)}${a.line2 ? '<br>' + esc(a.line2) : ''}</div>
        <div>${esc(a.city)}, ${esc(a.state)} ${esc(a.postal_code)}</div>
      </div>
    `;
  }

  function renderPaid(order: OrderData) {
    const firstName = (order.customer_name || '').trim().split(/\s+/)[0] || order.customer_name || '';
    root.className = 'order-success';
    root.innerHTML = `
      <header class="order-success__head">
        <div class="order-success__eyebrow">
          <span class="dot" aria-hidden="true"></span>
          <span>Order confirmed</span>
        </div>
        <h1 class="order-success__title">Thank you, <em>${esc(firstName)}.</em></h1>
        <p class="order-success__subtitle">Your order <strong>${esc(order.order_number)}</strong> has been received.</p>
      </header>
      ${buildSummaryHtml(order)}
      ${buildShippingHtml(order)}
      <p class="order-success__outro">We'll email you at <a href="mailto:${esc(order.customer_email)}">${esc(order.customer_email)}</a> when it ships.</p>
      <a href="/shop" class="order-summary__continue">Back to the shop &rarr;</a>
    `;
  }

  async function init() {
    const url = new URL(window.location.href);

    // Mutually exclusive state routing — exactly one state renders.
    if (url.searchParams.get('cancelled') === '1') {
      renderCancelled();
      return;
    }

    const sessionId = url.searchParams.get('session_id');
    if (!sessionId) {
      renderNotFound();
      return;
    }

    // Poll: every 2s, up to 15 attempts (30s)
    const MAX_ATTEMPTS = 15;
    const POLL_MS = 2000;
    let attempt = 0;
    let stopped = false;

    async function pollOnce(): Promise<void> {
      attempt += 1;
      try {
        const res = await fetch(
          `${API_BASE}/api/orders/by-session?session_id=${encodeURIComponent(sessionId!)}`,
          { headers: { 'Accept': 'application/json' } },
        );
        if (res.status === 404) {
          stopped = true;
          renderNotFound();
          return;
        }
        const json = await res.json();
        const order = json?.data as OrderData | undefined;
        if (json?.ok && order?.status === 'paid') {
          stopped = true;
          clearCart();
          renderPaid(order);
          return;
        }
      } catch {
        // transient — retry
      }

      if (attempt >= MAX_ATTEMPTS) {
        stopped = true;
        // Payment succeeded on Stripe's side; webhook is just catching up.
        clearCart();
        renderPending();
        return;
      }

      window.setTimeout(() => {
        if (stopped) return;
        void pollOnce();
      }, POLL_MS);
    }

    renderLoading();
    void pollOnce();
  }

  init();
</script>
