---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Order confirmed — Tacky Turquoise">
  <section class="storefront-page">
    <div class="storefront-page__inner">
      <div id="success-loading" class="storefront-loading">Loading your order…</div>

      <div id="success-notfound" hidden>
        <div class="cart-empty">
          <h2 class="cart-empty__title">We couldn't find that <em>order.</em></h2>
          <p class="cart-empty__sub">Check the link, or head back to the shop.</p>
          <a class="cart-empty__link" href="/">Back home <span aria-hidden="true">→</span></a>
        </div>
      </div>

      <div id="success-main" hidden class="order-success">
        <header class="order-success__head">
          <div class="order-success__eyebrow">
            <span class="dot" aria-hidden="true"></span>
            <span>Order confirmed</span>
          </div>
          <h1 class="order-success__title" id="success-title">Thank you.</h1>
          <p class="order-success__subtitle" id="success-subtitle"></p>
        </header>

        <div id="success-summary"></div>
        <div id="success-shipping"></div>

        <p class="order-success__outro" id="success-outro"></p>
        <a href="/shop" class="order-summary__continue">Back to the shop →</a>
      </div>
    </div>
  </section>
  <Footer />
</Base>

<script>
  import { clearCart } from '../../lib/cart';
  import { formatPrice } from '../../lib/format';
  import { renderSummaryRow, sumCents, type CartItemData } from '../../lib/cart-render';

  interface OrderItem {
    product_id: string;
    slug: string;
    piece_id: string | null;
    title: string;
    price_cents: number;
    primary_image_url: string | null;
  }
  interface OrderData {
    order_number: string;
    customer_name: string;
    customer_email: string;
    items: OrderItem[];
    subtotal_cents: number;
    shipping_cents: number;
    tax_cents?: number;
    total_cents: number;
    shipping_address: {
      line1: string;
      line2?: string | null;
      city: string;
      state: string;
      postal_code: string;
      country: string;
    };
  }

  const loadingEl = document.getElementById('success-loading')!;
  const notFoundEl = document.getElementById('success-notfound')!;
  const mainEl = document.getElementById('success-main')!;
  const titleEl = document.getElementById('success-title')!;
  const subtitleEl = document.getElementById('success-subtitle')!;
  const summaryEl = document.getElementById('success-summary')!;
  const shippingEl = document.getElementById('success-shipping')!;
  const outroEl = document.getElementById('success-outro')!;

  function esc(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function renderSummary(order: OrderData) {
    const items: CartItemData[] = order.items.map((it) => ({
      id: it.product_id,
      slug: it.slug,
      piece_id: it.piece_id,
      title: it.title,
      price_cents: it.price_cents,
      primary_image_url: it.primary_image_url,
      length: null,
      turquoise_type: null,
      metal: null,
    }));
    const subtotal = order.subtotal_cents ?? sumCents(items);
    const shipping = order.shipping_cents ?? 0;
    const tax = order.tax_cents ?? 0;
    const total = order.total_cents ?? subtotal + shipping + tax;

    summaryEl.innerHTML = `
      <div class="order-summary">
        <div class="order-summary__heading">Your order</div>
        <div class="order-summary__items">
          ${items.map((it) => renderSummaryRow(it)).join('')}
        </div>
        <div class="order-summary__lines">
          <div class="order-summary__line">
            <span class="label">Subtotal</span>
            <span class="value">${formatPrice(subtotal)}</span>
          </div>
          <div class="order-summary__line">
            <span class="label">Shipping</span>
            <span class="value">${formatPrice(shipping)}</span>
          </div>
          ${tax ? `
          <div class="order-summary__line">
            <span class="label">Tax</span>
            <span class="value">${formatPrice(tax)}</span>
          </div>` : ''}
        </div>
        <div class="order-summary__total">
          <span class="label">Total</span>
          <span class="value">${formatPrice(total)}</span>
        </div>
      </div>
    `;
  }

  function renderShipping(order: OrderData) {
    const a = order.shipping_address;
    shippingEl.innerHTML = `
      <div class="order-card">
        <div class="order-card__title">Shipping to</div>
        <div>${esc(order.customer_name)}</div>
        <div>${esc(a.line1)}${a.line2 ? '<br>' + esc(a.line2) : ''}</div>
        <div>${esc(a.city)}, ${esc(a.state)} ${esc(a.postal_code)}</div>
      </div>
    `;
  }

  async function init() {
    const url = new URL(window.location.href);
    const orderNumber = url.searchParams.get('order');

    if (!orderNumber) {
      loadingEl.hidden = true;
      notFoundEl.hidden = false;
      return;
    }

    try {
      const res = await fetch(`/api/orders/by-number?order=${encodeURIComponent(orderNumber)}`);
      if (!res.ok) {
        loadingEl.hidden = true;
        notFoundEl.hidden = false;
        return;
      }
      const json = await res.json();
      if (!json.ok || !json.data) {
        loadingEl.hidden = true;
        notFoundEl.hidden = false;
        return;
      }

      const order = json.data as OrderData;

      // Fire-and-forget mark-paid-stub. Idempotent per spec.
      fetch(`/api/orders/${encodeURIComponent(orderNumber)}/mark-paid-stub`, {
        method: 'POST',
      }).catch(() => {});

      // Clear cart immediately so badge drops to 0.
      clearCart();

      const firstName = (order.customer_name || '').trim().split(/\s+/)[0] || order.customer_name || '';
      titleEl.innerHTML = `Thank you, <em>${esc(firstName)}.</em>`;
      subtitleEl.innerHTML = `Your order <strong>${esc(order.order_number)}</strong> has been received.`;
      outroEl.innerHTML = `We'll email you at <a href="mailto:${esc(order.customer_email)}">${esc(order.customer_email)}</a> when it ships.`;

      renderSummary(order);
      renderShipping(order);

      loadingEl.hidden = true;
      mainEl.hidden = false;
    } catch {
      loadingEl.hidden = true;
      notFoundEl.hidden = false;
    }
  }

  init();
</script>
