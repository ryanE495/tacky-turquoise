---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ShopNewBanner from '../components/ShopNewBanner.astro';
import MeetTheMaker from '../components/MeetTheMaker.astro';
import EditorialBanner from '../components/EditorialBanner.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import Reviews from '../components/Reviews.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Handmade Turquoise Necklaces"
  description="One-of-a-kind beaded turquoise necklaces, handmade in Colorado. Each piece is unique. Shipped across the US."
>
  <Hero />
  <ShopNewBanner />
  <MeetTheMaker />
  <EditorialBanner
    eyebrow="One of one"
    title="Made to be"
    em="kept."
    sub="Beaded necklaces from a small studio in Montrose. One at a time, no two alike."
    cta="Shop the pieces"
    href="/shop"
    align="left"
    variant="short"
    image="https://ozxbjwvwchesjgebenbv.supabase.co/storage/v1/object/public/media/6610720e-2a1b-4fbb-8c5a-fc1cb65a2099.webp"
  />
  <FeaturedProducts />
  <Reviews />
  <Footer />
</Base>
