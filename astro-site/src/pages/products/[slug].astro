---
import '../../styles/tokens.css';
import '../../styles/global.css';
import '../../styles/components.css';
import '../../styles/shop.css';
import '../../styles/product.css';
import '../../styles/mobile-menu.css';

import Marquee from '../../components/Marquee.astro';
import Footer from '../../components/Footer.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import { fetchPublishedProducts, storageUrl, formatPrice, type ProductWithImages } from '../../lib/supabase';

const LOGO = 'https://bswmrfxdadcmuyhmsagv.supabase.co/storage/v1/object/public/portfolio-images/logo-new.svg';
const FALLBACK_IMG = 'https://bswmrfxdadcmuyhmsagv.supabase.co/storage/v1/object/public/portfolio-images/test.jpeg';

export async function getStaticPaths() {
  const products = await fetchPublishedProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props { product: ProductWithImages }
const { product } = Astro.props;

const images = product.product_images.length
  ? product.product_images.map((img) => ({ url: storageUrl(img.storage_path), alt: img.alt_text ?? product.title }))
  : [{ url: FALLBACK_IMG, alt: product.title }];

const now = Date.now();
const isSold = !!product.sold_at;
const isReserved = product.reserved_until && new Date(product.reserved_until).getTime() > now;
const available = !isSold && !isReserved;

const stockLabel = isSold ? 'Sold' : isReserved ? 'Reserved' : 'Available · 1 of 1';
const stockClass = isSold ? 'details__stock--sold' : isReserved ? 'details__stock--reserved' : 'details__stock--available';

const titleHtml = product.title.replace(/(\b\w+)$/, '<em>$1</em>');
const description = product.description ?? '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{product.title} — Tacky Turquoise</title>
    <meta name="description" content={product.meta_description ?? product.title} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Monoton&family=Sacramento&family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <Marquee />

    <nav class="shop-nav">
      <div class="shop-nav__links">
        <a href="/shop">Shop</a>
        <a href="/">Artists</a>
        <a href="/">Our Story</a>
        <a href="/">Journal</a>
      </div>
      <a href="/" class="shop-nav__logo"><img src={LOGO} alt="Tacky Turquoise" /></a>
      <div class="shop-nav__right">
        <a href="#">Search</a>
        <a href="#">Account</a>
        <a href="#" class="cart">Bag (0)</a>
        <button type="button" class="mobile-menu-trigger" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <section class="product">
      <div class="product__crumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <a href="/shop">Shop</a> &nbsp;/&nbsp; {product.title}
      </div>

      <div class="product__layout">
        <div class="gallery">
          <div class="gallery__main" id="gallery-main">
            {product.featured && !isSold && <span class="gallery__badge">Featured</span>}
            {isSold && <span class="gallery__badge gallery__badge--sold">Sold</span>}
            <button class="gallery__zoom" aria-label="Zoom" id="zoom-btn">
              <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" /><path d="M16 16 L21 21" /><path d="M11 8 V14 M8 11 H14" /></svg>
            </button>
            {images.map((img, i) => (
              <img
                src={img.url}
                alt={img.alt}
                class={i === 0 ? '' : 'is-hidden'}
                data-idx={i}
              />
            ))}
          </div>
          {images.length > 1 && (
            <div class="gallery__thumbs">
              {images.map((img, i) => (
                <button class={`gallery__thumb${i === 0 ? ' is-active' : ''}`} data-idx={i} aria-label={`View image ${i + 1}`}>
                  <img src={img.url} alt="" />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="details">
          <div class="details__eyebrow">
            <span class="dot"></span>
            {product.piece_id && <span class="piece-id">Piece {product.piece_id}</span>}
            <span>·</span>
            <span>1 of 1</span>
          </div>

          <h1 class="details__name" set:html={titleHtml}></h1>

          <div class="details__price-row">
            <span class="details__price">{formatPrice(product.price_cents)}</span>
            <span class={`details__stock ${stockClass}`}>{stockLabel}</span>
          </div>

          {product.meta_description && <p class="details__lede">{product.meta_description}</p>}

          <ul class="details__specs">
            {product.piece_id && <li><span>Piece ID</span><span>{product.piece_id}</span></li>}
            {product.length && <li><span>Length</span><span>{product.length}</span></li>}
            <li><span>Edition</span><span>1 of 1 · signed &amp; dated</span></li>
            <li><span>Materials</span><span>Sterling silver · natural turquoise</span></li>
            <li><span>Lead time</span><span>{available ? 'Ships in 3–5 days' : isReserved ? 'Currently reserved' : 'No longer available'}</span></li>
          </ul>

          <div class="details__actions">
            <button class="details__cta" disabled={!available} id="add-to-bag">
              <span>{isSold ? 'Sold' : isReserved ? 'Reserved' : 'Add to Bag'}</span>
              <span class="arrow">→</span>
            </button>
            <button class="details__fav" aria-label="Save" id="fav-btn">
              <svg viewBox="0 0 24 24"><path d="M12 20s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 5c-2.5 4.5-9.5 9-9.5 9z" /></svg>
            </button>
          </div>

          <div class="details__trust">
            <div class="trust-item"><strong>Real stone</strong>Never reconstituted</div>
            <div class="trust-item"><strong>Made by hand</strong>Gallup, NM</div>
            <div class="trust-item"><strong>Free returns</strong>Within 14 days</div>
          </div>
        </div>
      </div>
    </section>

    {description && (
      <section class="product-story">
        <div class="product-story__inner">
          <div class="product-story__label">About this piece</div>
          <div class="product-story__body">{description}</div>
        </div>
      </section>
    )}

    <div class="zoom-modal" id="zoom-modal" aria-hidden="true">
      <button class="zoom-modal__close" aria-label="Close zoom" id="zoom-close">×</button>
      <img id="zoom-img" src="" alt="" />
    </div>

    <Footer />
    <MobileMenu />

    <script>
      const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery__thumb');
      const mainImgs = document.querySelectorAll<HTMLImageElement>('.gallery__main img[data-idx]');
      const zoomBtn = document.getElementById('zoom-btn');
      const zoomModal = document.getElementById('zoom-modal')!;
      const zoomImg = document.getElementById('zoom-img') as HTMLImageElement;
      const zoomClose = document.getElementById('zoom-close');
      const favBtn = document.getElementById('fav-btn');

      let current = 0;

      function showIdx(idx: number) {
        current = idx;
        mainImgs.forEach((img) => {
          img.classList.toggle('is-hidden', +img.dataset.idx! !== idx);
        });
        thumbs.forEach((t) => {
          t.classList.toggle('is-active', +t.dataset.idx! === idx);
        });
      }

      thumbs.forEach((t) => {
        t.addEventListener('click', () => showIdx(+t.dataset.idx!));
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') showIdx((current - 1 + mainImgs.length) % mainImgs.length);
        if (e.key === 'ArrowRight') showIdx((current + 1) % mainImgs.length);
        if (e.key === 'Escape') zoomModal.classList.remove('is-open');
      });

      zoomBtn?.addEventListener('click', () => {
        const active = mainImgs[current];
        if (!active) return;
        zoomImg.src = active.src;
        zoomImg.alt = active.alt;
        zoomModal.classList.add('is-open');
      });
      zoomModal.addEventListener('click', () => zoomModal.classList.remove('is-open'));
      zoomClose?.addEventListener('click', (e) => {
        e.stopPropagation();
        zoomModal.classList.remove('is-open');
      });

      favBtn?.addEventListener('click', () => favBtn.classList.toggle('is-on'));
    </script>
  </body>
</html>
