---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { fetchPublishedProducts, storageUrl, formatPrice } from '../lib/supabase';
import { getProductImageUrl } from '../lib/image-url';

const FALLBACK_IMG = 'https://bswmrfxdadcmuyhmsagv.supabase.co/storage/v1/object/public/portfolio-images/test.jpeg';

const products = await fetchPublishedProducts();

type Category = 'necklace' | 'ring' | 'cuff' | 'earring' | 'belt' | 'other';
const categoryFromPieceId = (pieceId: string | null): Category => {
  const prefix = (pieceId ?? '').charAt(0).toUpperCase();
  if (prefix === 'N') return 'necklace';
  if (prefix === 'R') return 'ring';
  if (prefix === 'C') return 'cuff';
  if (prefix === 'E') return 'earring';
  if (prefix === 'B') return 'belt';
  return 'other';
};

const now = Date.now();
const stockFromProduct = (p: (typeof products)[number]) => {
  if (p.sold_at) return 'oos';
  if (p.reserved_until && new Date(p.reserved_until).getTime() > now) return 'low';
  return 'ok';
};

const parseLen = (len: string | null): number[] => {
  if (!len) return [];
  return Array.from(len.matchAll(/(\d+)/g)).map((m) => +m[1]);
};

const viewModels = products.map((p, i) => {
  const cat = categoryFromPieceId(p.piece_id);
  const lens = parseLen(p.length);
  const stock = stockFromProduct(p);
  const firstImage = p.product_images[0];
  const secondImage = p.product_images[1] ?? firstImage;
  return {
    id: p.id,
    idx: i,
    slug: p.slug,
    title: p.title,
    pieceId: p.piece_id,
    price: p.price_cents / 100,
    priceLabel: formatPrice(p.price_cents),
    cat,
    lens,
    stock,
    featured: p.featured,
    lenStr: p.length ?? 'One size',
    imgA: firstImage ? storageUrl(firstImage.storage_path) : FALLBACK_IMG,
    imgB: secondImage ? storageUrl(secondImage.storage_path) : FALLBACK_IMG,
  };
});

const categories: { key: 'all' | Category; label: string; em?: string }[] = [
  { key: 'all',      label: 'All ',      em: 'pieces' },
  { key: 'necklace', label: 'Necklaces' },
  { key: 'ring',     label: 'Rings' },
  { key: 'cuff',     label: 'Cuffs' },
  { key: 'earring',  label: 'Earrings' },
  { key: 'belt',     label: 'Belts' },
];

const catCount = (k: string) =>
  k === 'all' ? viewModels.length : viewModels.filter((p) => p.cat === k).length;

const tagLabel = (v: (typeof viewModels)[number]): { label: string; cls: string } | null => {
  if (v.stock === 'oos') return { label: 'Sold', cls: 'prod__tag--sold' };
  if (v.featured) return { label: 'Featured', cls: 'prod__tag--hot' };
  if (v.stock === 'low') return { label: 'Reserved', cls: '' };
  return null;
};
const stockLabel = (s: string) => (s === 'low' ? 'Reserved' : s === 'oos' ? 'Sold' : 'Available');
const stockClass = (s: string) => (s === 'low' ? 'is-low' : s === 'oos' ? 'is-oos' : '');

const titleHtml = (t: string) => t.replace(/(\b\w+)$/, '<em>$1</em>');

const availableLengths = Array.from(
  new Set(viewModels.flatMap((v) => v.lens))
).sort((a, b) => a - b);
---

<Base
  title="Shop All Pieces"
  description="Browse our current collection of handmade turquoise necklaces. Each piece is one-of-a-kind. New drops added regularly."
>
    <Nav current="shop" />

    <header class="shop-header">
      <div class="shop-header__crumb"><a href="/">Home</a> &nbsp;/&nbsp; Shop &nbsp;/&nbsp; All Pieces</div>
      <div class="shop-header__row">
        <h1 class="reveal">The <em>whole</em> <br />shop.</h1>
        <p class="shop-header__sub reveal">
          <strong>{viewModels.length} {viewModels.length === 1 ? 'piece' : 'pieces'}, every one 1 of 1.</strong>
          Made by hand. Nothing gets restocked — when it's gone, it's gone.
        </p>
      </div>
    </header>

    <div class="filters">
      <div class="filters__chips">
        <button class="chip chip--toggle" data-toggle="instock">✓ In stock only</button>

        {availableLengths.length > 0 && (
          <div class="filters__group">
            <span class="filters__group-label">Length</span>
            {availableLengths.map((l) => (
              <button class="chip" data-len={l}>{l}″</button>
            ))}
          </div>
        )}

        <div class="filters__group">
          <span class="filters__group-label">Price</span>
          <button class="chip" data-price="0-200">Under $200</button>
          <button class="chip" data-price="200-500">$200–500</button>
          <button class="chip" data-price="500-1000">$500–1k</button>
          <button class="chip" data-price="1000-99999">$1k+</button>
        </div>

        <button class="chip chip--clear" id="clear">Clear all</button>
      </div>

      <div class="filters__right">
        <div class="count-readout"><strong id="count-n">{viewModels.length}</strong> pieces</div>
        <div class="sort">
          Sort
          <select id="sort">
            <option value="featured">Featured</option>
            <option value="newest">Newest</option>
            <option value="low">Price: low → high</option>
            <option value="high">Price: high → low</option>
            <option value="stone">By stone</option>
          </select>
        </div>
      </div>
    </div>

    <section class="shop">
      {viewModels.length === 0 ? (
        <div class="empty is-show">
          <h3>The shop is <em>empty</em>.</h3>
          <p>New drops land every Tuesday — check back soon.</p>
        </div>
      ) : (
        <div class="shop__grid" id="grid">
          {viewModels.map((v) => {
            const tag = tagLabel(v);
            return (
              <a
                href={`/products/${v.slug}`}
                class={`prod reveal${v.stock === 'oos' ? ' is-oos' : ''}`}
                data-id={v.id}
                data-cat={v.cat}
                data-price={v.price}
                data-len={v.lens.join(',')}
                data-stock={v.stock}
                data-stone={v.pieceId ?? ''}
                data-idx={v.idx}
              >
                <div class="prod__img">
                  <img
                    class="prod__img-a"
                    src={getProductImageUrl(v.imgA, 'card')}
                    alt={v.title}
                    loading={v.idx < 4 ? 'eager' : 'lazy'}
                    fetchpriority={v.idx < 4 ? 'high' : 'auto'}
                    decoding="async"
                    width="400"
                    height="400"
                  />
                  <img
                    class="prod__img-b"
                    src={getProductImageUrl(v.imgB, 'card')}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="400"
                  />
                  {tag && <span class={`prod__tag ${tag.cls}`}>{tag.label}</span>}
                  <button class="prod__heart" aria-label="Save">
                    <svg viewBox="0 0 24 24"><path d="M12 20s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 5c-2.5 4.5-9.5 9-9.5 9z" /></svg>
                  </button>
                  <span class="prod__quick">
                    <span>{v.stock === 'oos' ? 'Waitlist' : 'View piece'}</span>
                    <span>→</span>
                  </span>
                </div>
                <div class="prod__row">
                  <span class="prod__name" set:html={titleHtml(v.title)}></span>
                  <span class="prod__price">{v.priceLabel}</span>
                </div>
                <div class="prod__meta">
                  <span>{v.pieceId ?? '—'} · {v.lenStr}</span>
                  <span class={`prod__stock ${stockClass(v.stock)}`}>{stockLabel(v.stock)}</span>
                </div>
              </a>
            );
          })}
        </div>
      )}
      <div class="empty" id="empty">
        <h3>Nothing <em>like that</em> right now.</h3>
        <p>Try loosening a filter — every piece is one of one, so selection is always thin.</p>
      </div>
    </section>

    <Footer />

    <script>
      const state = {
        cat: 'all' as string,
        instock: false,
        lens: new Set<string>(),
        prices: new Set<string>(),
        sort: 'featured' as string,
      };

      function applyFilters() {
        const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid .prod'));
        let visible = 0;
        cards.forEach((card) => {
          const cat = card.dataset.cat!;
          const price = +card.dataset.price!;
          const lens = card.dataset.len ? card.dataset.len.split(',').map(Number) : [];
          const stock = card.dataset.stock!;

          let ok = true;
          if (state.cat !== 'all' && cat !== state.cat) ok = false;
          if (state.instock && stock === 'oos') ok = false;
          if (state.lens.size && !lens.some((l) => state.lens.has(String(l)))) ok = false;
          if (state.prices.size) {
            const hit = [...state.prices].some((range) => {
              const [lo, hi] = range.split('-').map(Number);
              return price >= lo && price <= hi;
            });
            if (!hit) ok = false;
          }
          card.classList.toggle('is-hidden', !ok);
          if (ok) visible++;
        });

        const grid = document.getElementById('grid')!;
        const sorted = cards.slice().sort((a, b) => {
          switch (state.sort) {
            case 'low':    return +a.dataset.price! - +b.dataset.price!;
            case 'high':   return +b.dataset.price! - +a.dataset.price!;
            case 'newest': return +b.dataset.idx! - +a.dataset.idx!;
            case 'stone':  return a.dataset.stone!.localeCompare(b.dataset.stone!);
            default:       return +a.dataset.idx! - +b.dataset.idx!;
          }
        });
        sorted.forEach((el) => grid.appendChild(el));

        document.getElementById('count-n')!.textContent = String(visible);
        document.getElementById('empty')!.classList.toggle('is-show', visible === 0);
      }

      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const chip = target.closest<HTMLElement>('.chip');
        const sub = target.closest<HTMLElement>('.subnav__item');
        const heart = target.closest<HTMLElement>('.prod__heart');

        if (heart) {
          e.preventDefault();
          heart.classList.toggle('is-on');
          return;
        }

        if (sub) {
          document.querySelectorAll('.subnav__item').forEach((b) => b.classList.remove('is-active'));
          sub.classList.add('is-active');
          state.cat = sub.dataset.cat!;
          applyFilters();
          return;
        }

        if (chip?.id === 'clear') {
          state.instock = false;
          state.lens.clear();
          state.prices.clear();
          document.querySelectorAll('.chip.is-on').forEach((c) => c.classList.remove('is-on'));
          applyFilters();
          return;
        }

        if (chip?.dataset.toggle === 'instock') {
          state.instock = !state.instock;
          chip.classList.toggle('is-on', state.instock);
          applyFilters();
          return;
        }

        if (chip?.dataset.len) {
          chip.classList.toggle('is-on');
          if (chip.classList.contains('is-on')) state.lens.add(chip.dataset.len);
          else state.lens.delete(chip.dataset.len);
          applyFilters();
          return;
        }

        if (chip?.dataset.price) {
          chip.classList.toggle('is-on');
          if (chip.classList.contains('is-on')) state.prices.add(chip.dataset.price);
          else state.prices.delete(chip.dataset.price);
          applyFilters();
          return;
        }
      });

      document.getElementById('sort')!.addEventListener('change', (e) => {
        state.sort = (e.target as HTMLSelectElement).value;
        applyFilters();
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) if (e.isIntersecting) e.target.classList.add('in');
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>

    <script>
      // Live-sync product status. The page is statically generated, so any
      // product bought after build time still shows as available in the grid
      // until this script runs. We refetch status + sold_at on mount and
      // update each card that has transitioned to sold (or moved out of
      // published status).
      import { supabase } from '../lib/supabase';

      (async function () {
        const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid .prod[data-id]'));
        if (!cards.length) return;
        const ids = cards.map((c) => c.dataset.id!).filter(Boolean);
        if (!ids.length) return;

        try {
          const { data, error } = await supabase
            .from('products')
            .select('id, status, sold_at, reserved_until')
            .in('id', ids);
          if (error || !data) return;

          const now = Date.now();
          const byId = new Map(data.map((p: any) => [p.id, p]));

          let visibleCount = 0;

          cards.forEach((card) => {
            const p = byId.get(card.dataset.id!) as any | undefined;

            // Not returned or no longer published → sold
            const isSold = !p || p.status !== 'published' || !!p.sold_at;
            const isReserved = !isSold && p.reserved_until && new Date(p.reserved_until).getTime() > now;

            const stock = isSold ? 'oos' : isReserved ? 'low' : 'ok';
            card.dataset.stock = stock;

            // Update the sold visual state
            card.classList.toggle('is-oos', isSold);

            // Tag pill: swap to "Sold" if needed; remove unrelated tags
            const existingTag = card.querySelector<HTMLElement>('.prod__tag');
            if (isSold) {
              if (existingTag) {
                existingTag.textContent = 'Sold';
                existingTag.className = 'prod__tag prod__tag--sold';
              } else {
                const img = card.querySelector<HTMLElement>('.prod__img');
                if (img) {
                  const tag = document.createElement('span');
                  tag.className = 'prod__tag prod__tag--sold';
                  tag.textContent = 'Sold';
                  img.prepend(tag);
                }
              }
            } else if (isReserved && existingTag && !existingTag.textContent?.trim()) {
              existingTag.textContent = 'Reserved';
              existingTag.className = 'prod__tag';
            }

            // Quick-add overlay text
            const quick = card.querySelector<HTMLElement>('.prod__quick > span:first-child');
            if (quick) quick.textContent = isSold ? 'Waitlist' : 'View piece';

            // Meta row stock label
            const stockEl = card.querySelector<HTMLElement>('.prod__stock');
            if (stockEl) {
              stockEl.classList.remove('is-low', 'is-oos');
              if (isSold) { stockEl.textContent = 'Sold'; stockEl.classList.add('is-oos'); }
              else if (isReserved) { stockEl.textContent = 'Reserved'; stockEl.classList.add('is-low'); }
              else { stockEl.textContent = 'Available'; }
            }

            if (!card.classList.contains('is-hidden')) visibleCount++;
          });

          // Keep the count readout honest if the current filter shows everything.
          const readout = document.getElementById('count-n');
          if (readout) readout.textContent = String(visibleCount);
        } catch {
          // network errors: leave the baked-in state alone, user can refresh
        }
      })();
    </script>
</Base>
